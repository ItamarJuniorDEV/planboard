APP_NAME=Planboard
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de dados
# Para usar MySQL via docker-compose deste repositorio, use sqlite localmente
# ou aponte para o servico exposto na porta 3309.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3309
# DB_DATABASE=planboard
# DB_USERNAME=planboard
# DB_PASSWORD=

# Usado apenas pelo docker-compose para inicializar o MySQL local.
# DB_ROOT_PASSWORD=

# Sanctum: dominios que recebem cookie de sessao para autenticacao stateful (SPA)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# CORS: lista separada por virgula. Nao use wildcard quando supports_credentials=true.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: o projeto nao usa jobs, mantido como database para nao depender de Redis.
QUEUE_CONNECTION=database

# Cache: o projeto usa Cache::remember para project:{id}:stats. Driver de banco
# funciona em qualquer ambiente sem dependencia externa.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: em desenvolvimento o driver "log" escreve no storage/logs em vez de enviar.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
